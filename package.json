{
  "name": "ffb-fleet-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "FFB Fleet Management System — Logistic management for Fresh Fruit Bunch evacuation operations",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "npm run build && tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed": "tsx server/db/seed.ts",
    "db:reset": "tsx server/db/reset.ts",
    "lint": "eslint src/ server/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "@reduxjs/toolkit": "^2.5.0",
    "react-redux": "^9.2.0",
    "react-hook-form": "^7.54.0",
    "@hookform/resolvers": "^3.9.0",
    "zod": "^3.24.0",
    "@tanstack/react-virtual": "^3.11.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "recharts": "^2.15.0",
    "express": "^4.21.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^5.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.5.0",
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.19.0",
    "concurrently": "^9.1.0"
  }
}
